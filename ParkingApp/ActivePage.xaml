<Page x:Class="ViniParkingApp.ActivePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ActivePage" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Aktywne pozycje na parkingu" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1" Name="GridActiveParkings" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="#F2F6F8" HeadersVisibility="Column"/>
    </Grid>
</Page>
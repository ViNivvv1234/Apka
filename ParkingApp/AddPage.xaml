<Page x:Class="ViniParkingApp.AddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddPage" Background="White">

    <StackPanel Margin="30" Width="400" HorizontalAlignment="Left">

        <TextBlock Text="Rejestracja nowego pojazdu" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Imię klienta:" FontWeight="Bold" Margin="0,5,0,0"/>
        <TextBox Name="TxtImie" Margin="0,5,0,15" Padding="5" FontSize="14"/>

        <TextBlock Text="Nazwisko klienta:" FontWeight="Bold"/>
        <TextBox Name="TxtNazwisko" Margin="0,5,0,15" Padding="5" FontSize="14"/>

        <TextBlock Text="Numer rejestracyjny (np. WA12345):" FontWeight="Bold"/>
        <TextBox Name="TxtRejestracja" Margin="0,5,0,15" Padding="5" FontSize="14" CharacterCasing="Upper"/>

        <TextBlock Text="Wybierz wolne miejsce:" FontWeight="Bold"/>
        <ComboBox Name="CmbMiejsca" Margin="0,5,0,25" Padding="5" FontSize="14"/>

        <Button Content="Dodaj pojazd" Name="BtnSave" Click="BtnSave_Click"
                Background="#a1ffa2" Foreground="White" Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand"/>

    </StackPanel>
</Page>
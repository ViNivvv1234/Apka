<Window x:Class="ViniParkingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parking pod Vini Company" Height="600" Width="900" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#ffc2ce">
            <TextBlock Text="VINI PARKING" Foreground="White" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,30,0,30"/>

            <Button Content="Aktywne pozycje" Name="BtnActive" Click="BtnActive_Click" 
                    Height="50" Margin="10,5" Background="#c2ccff" Foreground="White" FontSize="16"/>

            <Button Content="Archiwum" Name="BtnArchive" Click="BtnArchive_Click" 
                    Height="50" Margin="10,5" Background="#baabff" Foreground="White" FontSize="16"/>

            <Button Content="Dodaj nową pozycję" Name="BtnAdd" Click="BtnAdd_Click" 
                    Height="50" Margin="10,5" Background="#c2ccff" Foreground="White" FontSize="16"/>

            <Button Content="Edycja pozycji" Name="BtnEdit" Click="BtnEdit_Click" 
                    Height="50" Margin="10,5" Background="#baabff" Foreground="White" FontSize="16"/>
        </StackPanel>

        <Frame Grid.Column="1" Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>